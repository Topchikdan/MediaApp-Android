<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="#2A2A3E" />
            <stroke android:width="1.5dp" android:color="#6C63FF" />
        </shape>
    </item>
    <item android:state_enabled="false">
        <shape android:shape="oval">
            <solid android:color="#0F0F13" />
            <stroke android:width="1.5dp" android:color="#2A2A3E" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <solid android:color="#1E1E2E" />
            <stroke android:width="1.5dp" android:color="#3D3D55" />
        </shape>
    </item>
</selector>